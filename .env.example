# Copy this file to .env and fill in the real values before running
# `docker compose up -d`. All variables are read by docker-compose.yml.

# --- Frontend ---------------------------------------------------------------

# Port exposed on the host for the nginx container
FRONTEND_PORT=8080

# API URL inlined into the Vite bundle at build time.
# Default "/api" keeps the frontend and backend on the same origin (nginx
# reverse-proxies /api/* to the backend service). Change only if you deploy the
# backend on a different host, e.g. "https://api.example.com".
VITE_API_URL=/api

# --- Backend ----------------------------------------------------------------

# Image name of the backend that implements openapi.yaml.
# Must listen on port 3000 and respond under /api/*.
BACKEND_IMAGE=genial-quizz-backend:latest

# Secret used to sign JWTs. Generate with: openssl rand -hex 48
JWT_SECRET=replace-me-with-a-long-random-string

# JWT lifetime (backend-specific; accepts "15m", "1h", "7d", ...)
JWT_EXPIRES_IN=7d

# Connection string used by the backend to reach the `db` service
DATABASE_URL=postgres://genial:replace-me@db:5432/genial_quizz

# --- PostgreSQL -------------------------------------------------------------

POSTGRES_DB=genial_quizz
POSTGRES_USER=genial
POSTGRES_PASSWORD=replace-me
